# Fastlane Snapfile
# Run: fastlane screenshots

# Required App Store device sizes
devices([
  "iPhone 17 Pro Max",  # 6.9" – required
  # "iPhone Air",       # 6.7" – required (disabled for debugging)
])

# All supported app languages
languages([
  "en-US",
  # "nl-NL",  # disabled for debugging
  # "de-DE",  # disabled for debugging
  # "fr-FR",  # disabled for debugging
  # "it-IT",  # disabled for debugging
])

# Xcode scheme (must have the UI test target in its Test action)
scheme("CookingApp")
test_target_name("CookingAppUITests")

# Path to the UI test target source folder
# (where SnapshotHelper.swift lives)
output_directory("./fastlane/screenshots")

clear_previous_screenshots(true)

# Clean status bar: 9:41 AM, full signal/battery
override_status_bar(true)

# Stop on first failure per language/device combo
stop_after_first_error(false)

# Write build log to a project-local path to avoid ~/Library/Logs permission issues
buildlog_path("./fastlane/buildlogs")

# Save test result bundle so it persists after the run
result_bundle(true)
